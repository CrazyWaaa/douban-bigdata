# Docker Compose 默认配置(Windows 本地)
# 复制为 .env 后再修改:D:\douban-bigdata> copy .env.example .env

# 所有数据落到 D 盘,严禁用 C 盘
DATA_ROOT=D:/douban-bigdata

# MySQL 默认账号
MYSQL_ROOT_PASSWORD=root_pwd
MYSQL_DB_NAME=douban
MYSQL_DB_USER=douban
MYSQL_DB_PASSWORD=douban_pwd

# 宿主端口(避免和本机已有 mysql/服务冲突)
MYSQL_HOST_PORT=3306
NGINX_HOST_PORT=8080

# 后端鉴权(留空 = 关闭鉴权,方便开发;生产请填值)
DOUBAN_API_KEY=
DOUBAN_RATE_LIMIT=60/minute