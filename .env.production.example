# ECS production example. Copy this file to .env and replace all CHANGE_ME values.
DATA_ROOT=/opt/douban-data
FRONTEND_DIST=/opt/douban-data/dist

MYSQL_ROOT_PASSWORD=CHANGE_ME_LONG_RANDOM_ROOT_PASSWORD
MYSQL_DB_NAME=douban
MYSQL_DB_USER=douban
MYSQL_DB_PASSWORD=CHANGE_ME_LONG_RANDOM_APP_PASSWORD

# MySQL is bound to 127.0.0.1 by docker-compose.yml. Do not open 3306 in the ECS security group.
MYSQL_HOST_PORT=3306

# Use 80 for direct IP access. If another host nginx owns ports 80/443, keep 8080.
NGINX_HOST_PORT=80

# Leave empty for the public read-only dashboard. The current browser client does not send X-API-Key.
DOUBAN_API_KEY=
DOUBAN_RATE_LIMIT=120/minute